<div class="max-w-md w-full bg-base-100 shadow-md rounded-2xl p-8 text-center">
  <h1 class="text-4xl font-bold text-gray-800 mb-4">
    <%= code %>
  </h1>

  <h2 class="text-xl font-semibold text-gray-700 mb-3">
    <%= title %>
  </h2>

  <p class="text-gray-500 mb-6">
    <%= message %>
  </p>

  <div class="space-y-3">
    <%= link_to "トップへ戻る",
                root_path,
                class: "block w-full  py-2 btn btn-primary" %>
  </div>
</div>