<main class="hero min-h-[70vh] bg-base-200">
  <div class="hero-content text-center">
    <div class="card w-full max-w-md shadow-xl bg-base-100">
    <div class="card-body">
      <h1 class="text-4xl font-bold text-center mb-4">
        ログイン
      </h1>
      <%= form_with url: login_path, local: true, class: "space-y-4" do |f| %>

        <!-- Email -->
        <div class="form-control">
          <%= f.label :email, "メールアドレス", class: "label" %>
          <%= f.email_field :email,
                class: "input input-bordered w-full",
                placeholder: "example@example.com" %>
        </div>

        <!-- Password -->
        <div class="form-control">
          <%= f.label :password, "パスワード", class: "label" %>
          <%= f.password_field :password,
                class: "input input-bordered w-full",
                placeholder: "3文字以上" %>
        </div>

        <!-- Submit -->
        <div class="form-control mt-6">
          <%= f.submit "ログインする", class: "btn btn-primary w-full" %>
        </div>

      <% end %>
    </div>
  </div>
  </div>
</main>

