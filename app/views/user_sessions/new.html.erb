    <% content_for :title do %>
      ログイン
    <% end %>

<div class="card w-full  shadow-xl bg-base-100">
  <div class="card-body">

    <%= form_with scope: :session, url: login_path, local: true, class: "space-y-4" do |f| %>

      <!-- Email -->
      <div class="form-control">
        <%= f.label :email, "メールアドレス", class: "label" %>
        <%= f.email_field :email,
              value: params.dig(:session, :email),
              class: "input input-bordered w-full",
              placeholder: "example@example.com",
              autocomplete: "email" %>
      </div>

      <!-- Password -->
      <div class="form-control">
        <%= f.label :password, "パスワード", class: "label" %>
        <%= f.password_field :password,
              class: "input input-bordered w-full",
              placeholder: "3文字以上",
              autocomplete: "current-password" %>
      </div>

      <!-- remember_me -->
      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-2">
          <%= f.check_box :remember_me, { checked: params.dig(:session, :remember_me).nil? ? true : params.dig(:session, :remember_me) == "1" }, "1", "0" %>
          <span class="label-text">ログイン状態を保持する</span>
        </label>
      </div>

      <!-- Submit -->
      <div class="form-control mt-6">
        <%= f.submit "ログインする", class: "btn btn-primary w-full" %>
      </div>

    <% end %>

    <%# Googleログインボタン %>

    <%= link_to auth_at_provider_path(provider: :google), class: "btn btn-outline btn-md normal-case font-medium gap-3 border-gray-300 hover:bg-gray-50 hover:border-gray-400 flex items-center" do %>
      <div class="gsi-material-button-icon ">
        <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" xmlns:xlink="http://www.w3.org/1999/xlink" class="w-5 h-5 block">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path>
          <path fill="none" d="M0 0h48v48H0z"></path>
        </svg>
      </div>
      <span class="text-gray-700">Googleでログイン</span>
    <% end %>
  </div>
</div>



