    <% if @if_then_rule_form.warnings.present? %>
    <div class="max-w-md mx-auto space-y-2">
      <% @if_then_rule_form.warnings.each do |warn_message|%>
      <p class="text-yellow-600 bg-yellow-50"> <%= warn_message %> </p>
      <% end %>
    </div>
    <% end %>

  <h1 class="text-4xl font-semi-bold text-center my-6">
    If-Thenルール作成
  </h1>

  <%= form_with model: @if_then_rule_form, url: if_then_rules_path,class: "max-w-md mx-auto space-y-6" do |f| %>
    <%= f.hidden_field :memo_id %>
  <div class="p-4 rounded-lg bg-blue-50 border border-blue-100">
    <div class="form-control">
      <%= f.label :if_condition, "IF（きっかけ）", class: "label" %>
      <%= f.text_field :if_condition,
                      class: "input input-bordered",
                      placeholder: "例：朝7時に起きたら" %>
      <% if @if_then_rule_form.errors[:if_condition].any? %>
        <p class="text-sm text-red-600 mt-1">
          <%= @if_then_rule_form.errors[:if_condition].first %>
        </p>
      <% end %>
    </div>





    <details class="mt-2 group">
      <summary class="text-sm text-gray-500 flex items-center gap-2 cursor-pointer list-none">
        <span class="transition-transform group-open:rotate-90">▶</span>
        IFのヒント
      </summary>

      <div class="mt-2 text-sm text-gray-600  p-3 rounded">
        💡  「いつ・どこで起きるか」が分かる条件にすると、気づきやすくなります。
        （例：「朝7時に起きたら」「会社に着いたら」）
      </div>
    </details>
  </div>
  <div class="p-4 rounded-lg bg-green-50 border border-green-100">
    <div class="form-control">
      <%= f.label :then_action, "THEN（行動）", class: "label" %>
      <%= f.text_field :then_action,
                      class: "input input-bordered",
                      placeholder: "例：コップ一杯の水を飲む" %>
      <% if @if_then_rule_form.errors[:then_action].any? %>
        <p class="text-sm text-red-600 mt-1">
          <%= @if_then_rule_form.errors[:then_action].first %>
        </p>
      <% end %>
    </div>

    <details class="mt-2 group">
      <summary class="text-sm text-gray-500 flex items-center gap-2 cursor-pointer list-none">
        <span class="transition-transform group-open:rotate-90">▶</span>
        THENのヒント
      </summary>

      <div class="mt-2 text-sm text-gray-600  p-3 rounded">
        💡  20秒以内にできる最初の一歩に分けると、実行しやすくなります。
        （例：「勉強する」→「ノートを開く」）
      </div>
    </details>
  </div>
    <div class="pt-4 space-y-3">
    <% if @if_then_rule_form.warnings.present? %>
      <%= f.button "無視して保存する",
                  name: "commit_type",
                  value: "ignore_warnings",
                  class: "btn btn-primary w-full" %>

      <%= f.button "もう一度確認する",
                  name: "commit_type",
                  value: "review",
                  class: "btn btn-secondary w-full" %>
    <% else %>
      <%= f.button "保存する",
                  class: "btn btn-primary w-full" %>
    <% end %>
  </div>
  <% end %>

<div class="max-w-md mx-auto">

<div class="mt-4 p-3 text-sm text-gray-700  bg-gray-50">
  <p class="font-semibold mb-2">✅  thenに関して作成前にチェック(機能には影響しません)</p>

  <label class="flex items-center gap-2">
    <input type="checkbox">
    20秒以内にできる行動になっている
  </label>

  <label class="flex items-center gap-2">
    <input type="checkbox">
    終わったかどうかが分かる
  </label>

  <label class="flex items-center gap-2">
    <input type="checkbox">
    実際に体を動かす行動が含まれている
  </label>
</div>
</div>