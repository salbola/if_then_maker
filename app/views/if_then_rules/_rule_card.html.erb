<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% if_then_rules.each do |rule| %>
        <div class="bg-[#eaf2fb] card shadow-md rounded-lg p-4 space-y-2">
          <!--ルールのifとthen-->
          <div class = "card-title">
            <h2 class="text-xs font-medium text-gray-500 text-left">
              もし
            </h2>
            <p class="text-sm text-gray-700 bg-blue-100 rounded px-2 py-1 shadow-xs">
              <%= rule.if_condition %>
            </p>

            <h2 class="text-xs font-medium text-gray-500 text-left">
              その時は
            </h2>
            <p class="text-sm font-semibold text-primary bg-green-100 rounded px-2 py-1 shadow-xs">
              <%= rule.then_action %>
            </p>
          </div>
          <!--ルールのステータス-->
          <div>
              <p class="tag bg-accent text-white inline-block  px-2.5 py-0.5 text-xs ">
                <%= rule.human_status%>
              </p>
          </div>
            <!--ルールの元になったメモ-->
          <div>
            <% if rule.memo.present? %>
              <p class="text-xs text-gray-400 mb-2">
                元メモ：<%= rule.memo.title.presence || "（無題）" %>
              </p>
            <% else %>
              <p class="text-xs text-gray-400 mb-2">
                元のメモがありません
              </p>
            <% end %>
          </div>
            <!--ボタン集-->
            <div class="card-actions justify-end mt-4">
              <%= link_to "詳細",
                          if_then_rule_path(rule),
                          class: "btn btn-outline btn-sm btn-primary" %>
              <%= link_to "編集",
                          edit_if_then_rule_path(rule),
                          class: "btn btn-outline btn-sm" %>
              <%= link_to "削除",
                if_then_rule_path(rule),
                data: {
                            turbo_method: :delete,
                            turbo_confirm: "このルールを削除しますか？" },
                  class: "btn btn-outline btn-error btn-sm"
              %>
            </div>
        </div>
      <% end %>
    </div>