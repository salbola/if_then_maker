<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% if_then_rules.each do |rule| %>
        <div class="bg-[#eaf2fb] card shadow-md rounded-lg p-4">
          <div class="card-body">
            <h2 class="text-sm font-medium text-gray-500 text-left">
              IF
            </h2>
            <p class="mb-2">
              <%= rule.if_condition %>
            </p>

            <h2 class="text-sm font-medium text-gray-500 text-left">
              THEN
            </h2>
            <p class="mb-4">
              <%= rule.then_action %>
            </p>
            <div>
              <p class="tag bg-accent text-white inline-block mr-2 px-2.5 py-0.5">
                <%= rule.human_status%>
              </p>
            </div>

            <% if rule.memo.present? %>
              <p class="text-xs text-gray-400 mb-2">
                元メモ：<%= rule.memo.title.presence || "（無題）" %>
              </p>
            <% end %>

            <div class="card-actions justify-end">
              <%= link_to "詳細見る",
                          if_then_rule_path(rule),
                          class: "btn btn-outline btn-sm" %>
            </div>
            <div class="card-actions justify-end">
              <%= link_to "編集する",
                          edit_if_then_rule_path(rule),
                          class: "btn btn-outline btn-sm" %>
            </div>
            <div class="card-actions justify-end">
            <%= link_to "削除する",
              if_then_rule_path(rule),
            data: {
                        turbo_method: :delete,
                        turbo_confirm: "このルールを削除しますか？" },
              class: "btn btn-outline btn-error btn-sm"
            %>
            </div>
          </div>
        </div>
      <% end %>
    </div>