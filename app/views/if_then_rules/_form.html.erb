<!--if_then_rule_formはフォームオブジェクト-->
<%= form_with model: if_then_rule_form, url: url, method: method, class: "max-w-md mx-auto space-y-6" do |f| %>
  <%= f.hidden_field :memo_id %>
  <div class="p-4 rounded-lg bg-blue-50 border border-blue-100">
    <div class="form-control">
      <%= f.label :if_condition, "IF（きっかけ）", class: "label" %>
      <%= f.text_field :if_condition,
                      class: "input input-bordered",
                      placeholder: "例：朝7時に起きたら" %>
      <% if if_then_rule_form.errors[:if_condition].any? %>
        <p class="text-sm text-red-600 mt-1">
          <%= if_then_rule_form.errors[:if_condition].first %>
        </p>
      <% end %>
      <% if if_then_rule_form.warnings.any? %>
        <% if_then_rule_form.warnings
            .filter { |w| w[:field] == :if_condition }
            .each do |warning| %>
          <p class="text-yellow-600 text-sm">
            <%= warning[:message] %>
          </p>
        <% end %>
      <% end %>
    </div>





    <details class="mt-2 group">
      <summary class="text-sm text-gray-500 flex items-center gap-2 cursor-pointer list-none">
        <span class="transition-transform group-open:rotate-90">▶</span>
        💡 実行しやすいIFのチェックポイント
      </summary>

      <div class="mt-2 text-sm text-gray-600  p-3 rounded">
        <ul class="space-y-1 list-disc list-inside">
          <li>自分がその瞬間に気づける条件になっている</li>
          <li>「いつ・どこで」が自然に思い浮かぶ</li>
          <li>毎日または頻繁に起きる出来事になっている</li>
          <li>場所・物・動作など環境と結びついている</li>
        </ul>

        <p class="mt-2 text-xs text-gray-500">
          例：「やる気が出たら」→「机に座ったら」
        </p>
      </div>
    </details>
  </div>
  <div class="p-4 rounded-lg bg-green-50 border border-green-100">
    <div class="form-control">
      <%= f.label :then_action, "THEN（行動）", class: "label" %>
      <%= f.text_field :then_action,
                      class: "input input-bordered",
                      placeholder: "例：コップ一杯の水を飲む" %>
      <% if if_then_rule_form.errors[:then_action].any? %>
        <p class="text-sm text-red-600 mt-1">
          <%= if_then_rule_form.errors[:then_action].first %>
        </p>
      <% end %>
      <% if if_then_rule_form.warnings.any? %>
        <% if_then_rule_form.warnings
            .filter { |w| w[:field] == :then_action }
            .each do |warning| %>
          <p class="text-yellow-600 text-sm">
            <%= warning[:message] %>
          </p>
        <% end %>
      <% end %>
    </div>

    <details class="mt-2 group">
      <summary class="text-sm text-gray-500 flex items-center gap-2 cursor-pointer list-none">
        <span class="transition-transform group-open:rotate-90">▶</span>
        💡 実行しやすいTHENのチェックポイント
      </summary>

      <div class="mt-2 text-sm text-gray-600  p-3 rounded">
        <ul class="space-y-1 list-disc list-inside">
          <li>20秒以内に始められる行動になっている</li>
          <li>終わったかどうかが自分で分かる</li>
          <li>実際に体を動かす行動が含まれている</li>
          <li>「〜しない」ではなく、やる行動で書かれている</li>
        </ul>

        <p class="mt-2 text-xs text-gray-500">
          例：「勉強する」→「ノートを開く」<br>
          例2：「スマホを見ない」→「スマホの代わりに本を1ページ読む」
        </p>
      </div>
    </details>
  </div>
   <%= f.label :status, "状態", class: "label" %>
   <%= f.select :status, [ ["実行中", "active"],["下書き", "draft"]], {selected: change_default_status(@active_if_then_rules,setted_status:if_then_rule_form.status)} %>


<% if if_then_rule_form.warnings.any? %>
        <% if_then_rule_form.warnings
            .filter { |w| w[:field] == :status }
            .each do |warning| %>
          <p class="text-yellow-600 text-sm">
            <%= warning[:message] %>
          </p>
        <% end %>
      <% end %>
   <p class="text-sm text-gray-500 mt-1">
  現在、実行中のルールは <%= @active_if_then_rules.length %> 件です
</p>
    <div class="pt-4 space-y-3">
    <% if if_then_rule_form.warnings.present? %>
      <% if if_then_rule_form.errors.empty? %>
        <%= f.button "無視して保存する",
                    name: "commit_type",
                    value: "ignore_warnings",
                    class: "btn btn-primary w-full" %>
      <% end %>

      <%= f.button "もう一度確認して保存する",
                  name: "commit_type",
                  value: "review",
                  class: "btn btn-secondary w-full" %>

    <% else %>
      <%= f.button "保存する",
                  class: "btn btn-primary w-full" %>
    <% end %>
  </div>
  <% end %>

